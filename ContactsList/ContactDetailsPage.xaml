<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ContactsList.ContactDetailsPage"
             Title=""
             BackgroundColor="Black">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Image
                Source="{Binding Photo}"
                HeightRequest="200"
                WidthRequest="200"
                HorizontalOptions="Center" />
            
            <Label
                Text="{Binding Name}"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="DarkGray"
                HorizontalOptions="Center" />

            <Label
                Text="{Binding Email}"
                FontSize="18"
                TextColor="DarkGray"
                HorizontalOptions="Center" />

            <Label
                Text="{Binding Phone}"
                FontSize="18"
                TextColor="DarkGray"
                HorizontalOptions="Center" />
            <Label
                Text="{Binding Description}"
                FontSize="18"
                TextColor="DarkGray"
                HorizontalOptions="Center" />

            <Button
                x:Name="BackButton"
                Text="Back"
                Clicked="BackButton_Clicked" />

        </VerticalStackLayout>
        
    </ScrollView>


</ContentPage>